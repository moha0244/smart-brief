# Variables d'environnement pour Smart Brief

# Base de données Supabase
NEXT_PUBLIC_SUPABASE_URL=votre_supabase_url
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# API Mistral pour OCR et embeddings
MISTRAL_API_KEY=votre_mistral_api_key

# API OpenAI (alternative pour embeddings)
OPENAI_API_KEY=votre_openai_api_key

# API iLovePDF pour nettoyage OCR
ILOVEPDF_PUBLIC_KEY=votre_ilovepdf_public_key
ILOVEPDF_SECRET_KEY=votre_ilovepdf_secret_key
